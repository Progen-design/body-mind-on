# =============================================================================
# Body & Mind ON – přehled proměnných prostředí (zkopíruj do .env.local / Vercel)
# =============================================================================
# Výchozí chování kódu: kanonická aplikace https://app.bodyandmindon.cz (odkazy v e-mailech atd.).
# Na Vercelu vždy nastav NEXT_PUBLIC_APP_URL=https://app.bodyandmindon.cz (Production i Preview, pokud
# mají jít e-maily a redirecty na živou app). Na Preview bez této proměnné použije kód VERCEL_URL.
# Povinné pro běh plánu + profilu: Supabase, OpenAI, Spoonacular. Zbytek dle funkcí.

# ── Supabase (DB + Auth) ───────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# MCP / CLI migrace (Dashboard → Account → Access tokens)
# SUPABASE_ACCESS_TOKEN=sbp_xxx
# SUPABASE_PAT=sbp_xxx
# SUPABASE_PROJECT_REF=abcd1234
# Přímé SQL migrace (Settings → Database → Connection string, URI)
DATABASE_URL=

# ── OpenAI (strukturovaný plán, recepty z /api/recipe, překlady) ─────────────
OPENAI_API_KEY=sk-...
# OPENAI_WEB_SEARCH_ENABLED=true
# OPENAI_DAILY_BUDGET_USD=5
# OPENAI_PLAN_RETRY_COUNT=3
# OPENAI_PLAN_MAX_TOKENS=4000

# ── Spoonacular (recepty, complexSearch, /api/spoonacular-recipe) ───────────
SPOONACULAR_API_KEY=
# Strop HTTP volání (complexSearch + information) na JEDEN běh resolve plánu. Default v kódu 90, max 200.
# SPOONACULAR_MAX_REQUESTS_PER_PLAN=90
# Práh shody receptu 0–1 (nižší = víc kandidátů může projít, víc API). Default v kódu 0.1.
# MEAL_CONFIDENCE_THRESHOLD=0.1
# Logování výsledků complexSearch do konzole (jen ladění)
# SPOONACULAR_DEBUG=1

# ── wger.de ─────────────────────────────────────────────────────────────────
# Veřejné API bez klíče – žádná proměnná.

# ── E-mail (Gmail SMTP) ─────────────────────────────────────────────────────
GMAIL_USER=email@gmail.com
GMAIL_APP_PASSWORD=
# GMAIL_FROM=...
EMAIL_FROM="Body & Mind ON <email@gmail.com>"

# ── URL aplikace (odkazy v e-mailech, OAuth redirect) ────────────────────────
NEXT_PUBLIC_APP_URL=https://app.bodyandmindon.cz
# APP_URL=https://app.bodyandmindon.cz
# NEXT_PUBLIC_MAIN_SITE_URL=https://bodyandmindon.cz
# NEXT_PUBLIC_FACEBOOK_URL=
# NEXT_PUBLIC_INSTAGRAM_URL=

# ── Trenér ───────────────────────────────────────────────────────────────────
TRAINER_EMAIL=info@bodyandmindon.cz
# TRAINER_GMAIL=...

# ── Google Kalendář (OAuth) ──────────────────────────────────────────────────
GOOGLE_CALENDAR_CLIENT_ID=.apps.googleusercontent.com
GOOGLE_CALENDAR_CLIENT_SECRET=

# ── Admin (/admin, některé /api/admin/*, calendar connect) ─────────────────
ADMIN_TOKEN=

# ── Stripe (test: pk_test_ / sk_test_ + test pricing table + test webhook) ──
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_STRIPE_PRICING_TABLE_ID=prctbl_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Cron (Vercel Cron → /api/cron/daily-digest; GitHub Actions → run-scheduler) ─
# openssl rand -hex 32 — musí sedět s tím, co pošle Vercel v Authorization u cronu.
CRON_SECRET=
# Kontrola propojení (env + DB, bez Spoonacular bodů): GET …/api/integrations-status
# Stejný nebo jiný secret pro ruční volání scheduleru (Bearer)
# AI_SCHEDULER_SECRET=

# ── AI úlohy (fronta ai_tasks) ──────────────────────────────────────────────
# V kódu je max. 1 úloha za běh i při vyšším čísle (timeout serverless).
# AI_SCHEDULER_MAX_TASKS_PER_RUN=1
# AI_AGENT_TIMEOUT_MS=70000
# AI_TASK_MAX_ATTEMPTS=3
# AI_TASK_PROCESSING_STALE_MINUTES=15

# ── UI média ─────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_API_ONLY_MEDIA=true

# ── Skripty (lokální smoke testy) ────────────────────────────────────────────
# BASE_URL=http://localhost:3000
# SMOKE_TEST_RECIPIENT=test@example.com

# ── Alternativa SMTP (assistant-intake) ─────────────────────────────────────
# SMTP_USER=
# SMTP_PASS=
