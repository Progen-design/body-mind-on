# Supabase (povinné pro DB a Auth)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Access token pro MCP (Cursor → Supabase) a migrace: https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN=sbp_xxx  (nebo SUPABASE_PAT)
# Připojení k DB pro migrace (Settings → Database → Connection string, URI)
# DATABASE_URL=postgresql://postgres.[ref]:[HESLO]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# E-mail (Gmail SMTP – body-metrics, assistant-intake, mail.js)
GMAIL_USER=email@gmail.com
GMAIL_APP_PASSWORD=app-password
# Odpovědní adresa pro e-maily (fallback: GMAIL_USER). GMAIL_FROM je také akceptován.
EMAIL_FROM="Body & Mind ON <email@gmail.com>"

# Alternativa: SMTP (assistant-intake fallback)
# SMTP_USER=email@gmail.com
# SMTP_PASS=app-password

# OpenAI (AI plány – Responses API, instrukce v kódu lib/assistantInstructions.js)
OPENAI_API_KEY=sk-...
# Web search pro trenéra a kouče – autonomní vyhledávání aktuálních informací (výživa, suplementace, trendy)
# OPENAI_WEB_SEARCH_ENABLED=true

# Externí enrichment zdroje pro jídla a cviky
# Zobrazovat obrázky/média pouze z ověřených API (Spoonacular, wger)
# NEXT_PUBLIC_API_ONLY_MEDIA=true
SPOONACULAR_API_KEY=spoonacular-api-key
# Cviky: wger.de – veřejné API bez klíče (https://wger.de/api/v2/)

# Trenér – e-mail účtu trenéra (může přidávat události do kalendáře, vidí své události). TRAINER_GMAIL je také akceptován.
TRAINER_EMAIL=info@bodyandmindon.cz

# Google Kalendář (OAuth – propojení kalendáře trenéra, digest)
GOOGLE_CALENDAR_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CALENDAR_CLIENT_SECRET=xxx

# Admin panel (pro přístup k /api/auth/google-calendar/connect?key=...)
# Vygeneruj náhodný řetězec (např. random.org: 1 řetězec, 32 znaků, písmena+čísla) a vlož sem:
ADMIN_TOKEN=secret-token-pro-admin

# URL aplikace (e-mailové odkazy)
NEXT_PUBLIC_APP_URL=https://app.bodyandmindon.cz

# Stripe (Pricing Table na profilu po vypršení trialu + webhook)
# Publishable key (pk_test_... / pk_live_...) – veřejný, v prohlížeči
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# ID Pricing Table z Stripe Dashboard (Products → Pricing tables)
NEXT_PUBLIC_STRIPE_PRICING_TABLE_ID=prctbl_...
# Secret key (sk_test_... / sk_live_...) – POUZE na serveru, nikdy do prohlížeče
STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret (whsec_...) – Stripe Dashboard → Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Cron – denní e-mail (Vercel Cron volá /api/cron/daily-digest; nastav v Vercelu)
# Vygeneruj: openssl rand -hex 32
CRON_SECRET=your-secret-for-cron-auth
