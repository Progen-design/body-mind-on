# Zkopíruj jako .env.local (soubor je v .gitignore – necommitovat).
#
# Nejrychleji: přihlas se (`vercel login`), v kořeni repa `vercel link`, pak:
#   npm run env:pull        → stáhne Production proměnné z Vercelu do .env.local
#   npm run env:pull:preview / env:pull:dev  → jiné prostředí
# Pro čistě lokální odkazy přidej na konec .env.local:
#   NEXT_PUBLIC_APP_URL=http://localhost:3000
# (v Supabase Auth → URL Configuration přidej http://localhost:3000 jako redirect.)
#
# Supabase MCP – viz scripts/mcp-supabase-start.mjs a .cursor/mcp.json

SUPABASE_ACCESS_TOKEN=
# Volitelné – výchozí ref je v mcp-supabase-start.mjs
# SUPABASE_PROJECT_REF=

# Aplikace (lokální vývoj) – doplň podle vlastního projektu
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# OPENAI_API_KEY=
# SPOONACULAR_API_KEY=
#
# Volitelně: vlastní základ pro smoke e-mail (výchozí je info@… → info+bm-smoke-…@bodyandmindon.cz)
# SMOKE_TEST_RECIPIENT=info@bodyandmindon.cz
