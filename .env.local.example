# Zkopíruj jako .env.local (soubor je v .gitignore – necommitovat).
#
# Doporučený postup: přihlas se (`vercel login`), v kořeni repa `vercel link`, pak:
#   npm run env:pull        → stáhne Production proměnné z Vercelu do .env.local
# Ujisti se, že v .env.local je NEXT_PUBLIC_APP_URL=https://app.bodyandmindon.cz
# (odkazy v e-mailech a serverová logika pak vždy míří na produkční app).
#
# Supabase MCP – viz scripts/mcp-supabase-start.mjs a .cursor/mcp.json

SUPABASE_ACCESS_TOKEN=
# Volitelné – výchozí ref je v mcp-supabase-start.mjs
# SUPABASE_PROJECT_REF=

# Aplikace – doplň podle vlastního projektu, pokud netaháš z Vercelu
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# OPENAI_API_KEY=
# SPOONACULAR_API_KEY=
#
# Volitelně: vlastní základ pro smoke e-mail (výchozí je info@… → info+bm-smoke-…@bodyandmindon.cz)
# SMOKE_TEST_RECIPIENT=info@bodyandmindon.cz
