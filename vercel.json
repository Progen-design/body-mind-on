            },
            {
                  "path": "/api/cron/withings-sync",
                  "schedule": "0 5 * * *"
            },
            {
                  "path": "/api/cron/apple-health-daily-review",
                  "schedule": "0 5 * * *"
            },
            {
                  "path": "/api/cron/lifecycle-email",
