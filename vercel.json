            "pages/api/cron/apple-health-daily-review.js": {
                  "maxDuration": 300
            },
            "pages/api/cron/system-health-alert.js": {
                  "maxDuration": 60
            },
            "pages/api/cron/daily-adherence-sync.js": {
                  "maxDuration": 120
